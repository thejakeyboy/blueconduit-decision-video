{
  "name": "blueconduit-remotion-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype Remotion conference-booth product demo loop for BlueConduit.",
  "scripts": {
    "dev": "remotion studio src/index.tsx",
    "render": "remotion render src/index.tsx ConferenceBoothDemo out/blueconduit-conference-demo.mp4 --codec=h264 --crf=18",
    "render:fast": "remotion render src/index.tsx ConferenceBoothDemo out/blueconduit-conference-demo-preview.mp4 --codec=h264 --crf=23 --jpeg-quality=80 --concurrency=2"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.386",
    "@remotion/player": "^4.0.386",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remotion": "^4.0.386",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
